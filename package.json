{
  "name": "lens-lounge",
  "version": "2.0.0",
  "description": "NestJS app by PostgreSQL (Prisma). My first steps work with NodeJS, Express, NestJS, Microservices, RabbitMQ, WebSocket, Docker + kubernetes + jenkins, SOLID, Hexagonal architecture, SAGA,front-end basics.",
  "author": "Serge Hall",
  "private": true,
  "license": "MIT",
  "packageManager": "yarn@4.14.1",
  "engines": {
    "node": "24.15.0"
  },
  "scripts": {
    "build": "yarn build:lens-lounge",
    "build:all": "yarn build:lens-lounge && yarn build:payment-service && yarn build:file-service",
    "build:file-service": "nest build file-service",
    "build:lens-lounge": "nest build lens-lounge",
    "build:payment-service": "nest build payment-service",
    "fix": "yarn lint:fix && yarn format:prettier",
    "format": "yarn format:prettier",
    "format:prettier": "prettier --write --no-error-on-unmatched-pattern \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev.lens-lounge": "nest start lens-lounge --watch",
    "start:dev.payment-service": "nest start payment-service --watch",
    "start:dev.file-service": "nest start file-service --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/lens-lounge/main",
    "start:prod:file-service": "node dist/apps/file-service/main",
    "start:prod:payment-service": "node dist/apps/payment-service/main",
    "lint": "yarn lint:check",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:check": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "typecheck": "tsc --noEmit -p apps/lens-lounge/tsconfig.app.json && tsc --noEmit -p apps/payment-service/tsconfig.app.json && tsc --noEmit -p apps/file-service/tsconfig.app.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "yarn test:e2e:lens-lounge && yarn test:e2e:payment-service && yarn test:e2e:file-service",
    "test:e2e:file-service": "jest --config ./apps/file-service/test/jest-e2e.json --runInBand",
    "test:e2e:lens-lounge": "jest --config ./apps/lens-lounge/test/jest-e2e.json --runInBand",
    "test:e2e:payment-service": "jest --config ./apps/payment-service/test/jest-e2e.json --runInBand"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/platform-socket.io": "^11.1.28",
    "@nestjs/swagger": "^11.4.6",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.28",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "cookie-parser": "^1.4.7",
    "joi": "^17.13.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.28",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.3",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^30.4.2",
    "prettier": "^3.9.6",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.9.3",
    "webpack": "^5.108.4"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "\\.e2e-spec\\.ts$"
    ],
    "roots": [
      "<rootDir>/apps/"
    ]
  }
}
