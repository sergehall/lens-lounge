{
  "name": "lens-lounge",
  "version": "2.0.0",
  "description": "NestJS app by PostgreSQL (Prisma). My first steps work with NodeJS, Express, NestJS, Microservices, RabbitMQ, WebSocket, Docker + kubernetes + jenkins, SOLID, Hexagonal architecture, SAGA,front-end basics.",
  "author": "Serge Hall",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": "24.15.0"
  },
  "scripts": {
    "build": "nest build",
    "fix": "yarn lint:fix && yarn format:prettier",
    "format": "yarn format:prettier",
    "format:prettier": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev.lens-lounge": "nest start lens-lounge --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/lens-lounge/main",
    "lint": "yarn lint:check",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "lint:check": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/lens-lounge/test/jest-e2e.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1065.0",
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/microservices": "^11.1.24",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/platform-socket.io": "^11.1.24",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.24",
    "@prisma/adapter-pg": "^5.13.0",
    "@prisma/client": "^5.13.0",
    "@types/cookie-parser": "^1.4.7",
    "@types/joi": "^17.2.3",
    "@types/pg": "^8.11.5",
    "@types/reflect-metadata": "^0.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "joi": "^17.13.0",
    "pg": "^8.11.5",
    "prisma": "^5.13.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@aws-sdk/credential-provider-sso": "^3.972.51",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.24",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^24.13.1",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@typescript-eslint/utils": "^8.60.1",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.9.3",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/"
    ]
  }
}
